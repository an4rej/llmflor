# MySQL 8.0 (Timeweb / локально). Скопируйте в .env в корне проекта или выше public_html
# и подставьте пароль из панели хостинга. Файл .env не коммитьте.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=cv028576_llmflo
DB_USER=cv028576_llmflo
DB_PASSWORD=замените_на_пароль_из_панели
DB_CHARSET=utf8mb4

# Опционально: для PDO
DB_COLLATION=utf8mb4_unicode_ci
